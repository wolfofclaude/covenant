# Covenant — environment template (Phase 1)
# Copy to .env.local and fill in. .env.local is git-ignored.
# Nothing here is wired up yet; this documents the service surface
# the Phase 1 build needs. See the plan for context.

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (PostgreSQL) ──
# Local dev: docker compose up -d  →  postgresql://covenant:covenant@localhost:5432/covenant
# Production: DO Managed Postgres (or a UAE-region Postgres at launch).
DATABASE_URL=postgresql://covenant:covenant@localhost:5432/covenant

# ── Auth.js (NextAuth) ──
# Generate: openssl rand -base64 32
AUTH_SECRET=
# Google OAuth (Google Cloud console)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# UAE Pass OIDC (sandbox first: https://docs.uaepass.ae)
UAEPASS_CLIENT_ID=
UAEPASS_CLIENT_SECRET=
UAEPASS_ISSUER=https://stg-id.uaepass.ae   # staging issuer; switch to prod at launch

# ── Payments (Ziina, AED) ──
# API key from the Ziina Business portal. Leave blank for local demo mode
# (checkout then completes without taking a payment).
ZIINA_API_KEY=
# Optional: shared secret to verify webhook signatures (X-Hmac-Signature).
ZIINA_WEBHOOK_SECRET=

# ── Transactional email (Resend or AWS SES) ──
RESEND_API_KEY=
EMAIL_FROM=hello@covenant.ae

# ── Together AI (article generator) ──
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ── Document vault storage (encrypted; e.g. S3-compatible in UAE region) ──
VAULT_BUCKET=
VAULT_REGION=me-central-1
VAULT_ACCESS_KEY_ID=
VAULT_SECRET_ACCESS_KEY=
# Key for encrypting documents at rest (32-byte base64). Generate: openssl rand -base64 32
VAULT_ENCRYPTION_KEY=
